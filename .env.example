# ══════════════════════════════════════════════════════
#  كيان للعقارات — Environment Variables (EXAMPLE)
#  Copy this to .env.local and fill in real values
# ══════════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ─────────────────────
# Pooler URL — used at runtime on Vercel (port 6543)
DATABASE_URL="postgresql://postgres.YOURREF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL — used for prisma db push / migrations (port 5432)
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOURREF.supabase.co:5432/postgres"

# ── App ────────────────────────────────────────────────
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
NEXTAUTH_URL=https://your-app.vercel.app

# ── Admin ──────────────────────────────────────────────
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD_HASH=BCRYPT_HASH_OF_ADMIN_PASSWORD

# ── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=كيان للعقارات <noreply@yourdomain.com>

# ── Supabase Storage ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOURREF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── WhatsApp ───────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=201234567890

# ── Cron ──────────────────────────────────────────────
CRON_SECRET=RANDOM_SECRET_STRING
